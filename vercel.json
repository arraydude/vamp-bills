{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @vamp-bills/frontend build",
  "outputDirectory": "packages/frontend/dist",
  "rewrites": [
    { "source": "/trpc/(.*)", "destination": "/api/index" },
    { "source": "/api/auth/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "{packages/backend/{src,drizzle}/**,node_modules/.pnpm/@trpc+server*/node_modules/@trpc/server/dist/index.mjs}"
    }
  }
}
