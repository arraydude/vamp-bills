# ---- Database ----
# Local: postgres via docker-compose. Prod: Neon (https://neon.tech) connection string.
DATABASE_URL=postgresql://vamp:vamp@localhost:5432/vamp

# ---- BetterAuth ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# In dev: matches the Vite frontend origin. In prod: the Vercel deployment URL.
BETTER_AUTH_URL=http://localhost:5173

# ---- Google OAuth ----
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- AI Invoice Extraction ----
# Free key from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
