# Vercel deploy upload — keep it lean. Mirrors .gitignore plus repo-only artifacts.

# Repo docs / planning — not part of the runtime
docs/
scripts/*.py
.claude/
.agents/
skills-lock.json
AGENTS.md
CLAUDE.md
README.md

# CI / VCS
.github/
.git/

# Dev-only
.venv/
docker-compose.yml
.env.example

# Build outputs are regenerated by Vercel
dist/
build/
*.tsbuildinfo

# Local env (Vercel env vars come from project settings, not files)
.env
.env.local
.env.*.local
