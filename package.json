{
  "name": "vamp-bills",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "biome format --write .",
    "lint": "biome lint . && pnpm -r lint:eslint",
    "lint:fix": "biome lint --write . && pnpm -r lint:eslint:fix",
    "check": "biome check --write . && pnpm -r lint:eslint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @vamp-bills/backend db:generate",
    "db:push": "pnpm --filter @vamp-bills/backend db:push",
    "auth:generate": "pnpm --filter @vamp-bills/backend auth:generate",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --staged --write --no-errors-on-unmatched && git update-index --again"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vercel/config": "^0.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.19"
  },
  "pnpm": {
    "overrides": {
      "zod-validation-error": "^4.0.0"
    }
  },
  "dependencies": {
    "csv-parse": "^6.2.1"
  }
}
