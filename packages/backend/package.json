{
  "name": "@vamp-bills/backend",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./*.ts": "./src/*.ts",
    "./trpc/router": "./src/trpc/router.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:eslint:fix": "eslint . --max-warnings 0 --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "auth:generate": "better-auth generate --output src/db/auth-schema.ts --yes"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.71",
    "@trpc/server": "^11.17.0",
    "ai": "^6.0.177",
    "better-auth": "1.4.21",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "xstate": "^5.31.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
